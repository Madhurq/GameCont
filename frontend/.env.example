# GameCont Frontend Environment Variables
# Copy this file to .env and fill in your values

# API base URL (Spring Boot backend)
VITE_API_URL=http://localhost:8080/api

# WebSocket URL (STOMP over SockJS)
VITE_WS_URL=http://localhost:8080/ws

# WebSocket reconnect backoff (ms)
VITE_WS_RECONNECT_DELAY=5000
VITE_WS_MAX_RECONNECT_DELAY=30000
