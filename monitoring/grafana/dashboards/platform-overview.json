          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "jvm_memory_used_bytes{job=\"platform-api\",area=\"heap\"}",
          "legendFormat": "Used Heap",
          "range": true,
          "refId": "A"
